@model SeatDetailViewModel
@{
    ViewData["Title"] = $"座位 {@Model.SeatNumber}";
}

<h2>座位详情</h2>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <h4>@Model.SeatNumber</h4>
        <p class="text-muted">@Model.Floor · @Model.Area</p>
        <p>
            状态：
            @if (!Model.IsEnabled)
            {
                <span class="badge bg-secondary">已禁用</span>
            }
            else
            {
                <span class="badge bg-success">可用</span>
            }
        </p>
        @if (Model.IsEnabled && !string.IsNullOrEmpty(Model.CurrentUserName))
        {
            <a asp-controller="Reservation" asp-action="Create" asp-route-seatId="@Model.Id"
               class="btn btn-primary">预约此座位</a>
        }
        else if (Model.IsEnabled && string.IsNullOrEmpty(Model.CurrentUserName))
        {
            <p class="text-muted">请先选择身份后再预约</p>
        }
    </div>
</div>

<h5>今日时段占用（@DateTime.Today.ToString("yyyy-MM-dd")）</h5>
@if (Model.TimeSlots.Count == 0)
{
    <p class="text-muted">暂无时段数据</p>
}
else
{
    <div class="row g-2">
        @foreach (var slot in Model.TimeSlots)
        {
            <div class="col-md-3 col-sm-4 col-6">
                <div class="p-2 text-center border rounded @(slot.IsOccupied ? "bg-warning bg-opacity-25 border-warning" : "bg-success bg-opacity-10 border-success")">
                    <small>@slot.Label</small><br />
                    <span class="badge @(slot.IsOccupied ? "bg-warning" : "bg-success")">
                        @(slot.IsOccupied ? "已占用" : "空闲")
                    </span>
                </div>
            </div>
        }
    </div>
}

<div class="mt-3">
    <a asp-action="Index" class="btn btn-outline-secondary">返回列表</a>
</div>
