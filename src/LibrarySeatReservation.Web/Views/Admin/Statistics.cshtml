@model AdminStatisticsViewModel
@{
    ViewData["Title"] = "统计";
    Layout = "~/Views/Admin/Shared/_Layout.cshtml";
}

<h2>统计</h2>

@if (Model.TotalReservations == 0)
{
    <div class="text-center mt-5 py-5">
        <div class="display-1 text-muted mb-3">📊</div>
        <h4 class="text-muted">暂无数据</h4>
        <p class="text-muted">请先添加座位和预约记录</p>
    </div>
}
else
{
    <div class="row g-3 mt-2">
        <div class="col-sm-6 col-md-3">
            <div class="card text-center shadow-sm h-100">
                <div class="card-body d-flex flex-column justify-content-center">
                    <h3 class="display-6 text-primary mb-1">@Model.TodayReservations</h3>
                    <p class="card-text text-muted small mb-0">今日预约数</p>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-md-3">
            <div class="card text-center shadow-sm h-100">
                <div class="card-body d-flex flex-column justify-content-center">
                    <h3 class="display-6 text-warning mb-1">@Model.ActiveReservations</h3>
                    <p class="card-text text-muted small mb-0">当前有效预约</p>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-md-3">
            <div class="card text-center shadow-sm h-100">
                <div class="card-body d-flex flex-column justify-content-center">
                    <h3 class="display-6 text-info mb-1">@Model.SeatUsageRate%</h3>
                    <p class="card-text text-muted small mb-0">座位使用率</p>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-md-3">
            <div class="card text-center shadow-sm h-100">
                <div class="card-body d-flex flex-column justify-content-center">
                    <h3 class="display-6 text-secondary mb-1">@Model.TotalReservations</h3>
                    <p class="card-text text-muted small mb-0">历史总预约</p>
                </div>
            </div>
        </div>
    </div>
}
