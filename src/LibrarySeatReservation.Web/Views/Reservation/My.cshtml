@model MyReservationsViewModel
@{
    ViewData["Title"] = "我的预约";
}

<h2>我的预约</h2>

@if (Model.Reservations.Count == 0)
{
    <div class="text-center mt-5 py-5">
        <div class="display-1 text-muted mb-3">📋</div>
        <h4 class="text-muted">你还没有预约记录</h4>
        <p class="text-muted">去预约一个座位吧</p>
        <a asp-controller="Seats" asp-action="Index" class="btn btn-primary">去预约</a>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>座位</th>
                    <th>楼层</th>
                    <th>区域</th>
                    <th>时段</th>
                    <th>状态</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model.Reservations)
                {
                    <tr>
                        <td>@r.Seat?.SeatNumber</td>
                        <td>@r.Seat?.Floor</td>
                        <td>@r.Seat?.Area</td>
                        <td>@r.StartTime.ToString("MM/dd HH:mm") - @r.EndTime.ToString("HH:mm")</td>
                        <td>
                            <span class="badge @(r.Status == "待使用" ? "bg-primary" : r.Status == "已完成" ? "bg-success" : "bg-secondary")">
                                @r.Status
                            </span>
                        </td>
                        <td>
                            @if (r.Status == "待使用")
                            {
                                <form asp-action="Cancel" asp-route-id="@r.Id" method="post"
                                      onsubmit="return confirm('确定取消此预约？');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">取消预约</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
