@model AdminReservationsViewModel
@{
    ViewData["Title"] = "预约管理";
    Layout = "~/Views/Admin/Shared/_Layout.cshtml";
}

<h2>预约管理</h2>

<div class="row mb-3">
    <div class="col-md-3">
        <form method="get" class="d-flex gap-2">
            <select name="status" class="form-select" onchange="this.form.submit()">
                @foreach (var opt in Model.StatusOptions)
                {
                    <option value="@opt" selected="@(opt == Model.CurrentStatus)">@opt</option>
                }
            </select>
        </form>
    </div>
</div>

@if (Model.Reservations.Count == 0)
{
    <div class="text-center mt-5 py-5">
        <div class="display-1 text-muted mb-3">📋</div>
        <h4 class="text-muted">暂无预约记录</h4>
    </div>
}
else
{
    <div style="overflow-x:auto;">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>座位</th>
                    <th>预约人</th>
                    <th>时段</th>
                    <th>状态</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model.Reservations)
                {
                    <tr>
                        <td>@r.Id</td>
                        <td>@r.Seat?.SeatNumber</td>
                        <td>@r.UserName</td>
                        <td>@r.StartTime.ToString("MM/dd HH:mm") - @r.EndTime.ToString("HH:mm")</td>
                        <td>
                            <span class="badge @(r.Status == "待使用" ? "bg-primary" : r.Status == "已完成" ? "bg-success" : "bg-secondary")">
                                @r.Status
                            </span>
                        </td>
                        <td>
                            @if (r.Status == "待使用")
                            {
                                <form asp-action="MarkDone" asp-route-id="@r.Id" method="post" style="display:inline">
                                    <button type="submit" class="btn btn-sm btn-success">标记完成</button>
                                </form>
                                <form asp-action="Cancel" asp-route-id="@r.Id" method="post" style="display:inline"
                                      onsubmit="return confirm('确定取消此预约？');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">取消</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
